<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.argus.rag.document.readiness.mapper.DocumentReadinessIssueMapper">
    <select id="selectByBatchId" resultType="com.argus.rag.document.readiness.model.vo.DocumentReadinessIssueVO">
        select id,
               item_id as itemId,
               issue_type as issueType,
               severity,
               message,
               suggestion,
               created_at as createdAt
        from document_readiness_issues
        where batch_id = #{batchId}
        order by item_id asc, id asc
    </select>
</mapper>
